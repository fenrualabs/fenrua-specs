{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:fenrua:schema:receipt-v1",
  "title": "Fenrua receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "receiptId",
    "bundleId",
    "decisionId",
    "decision",
    "subjectId",
    "actorId",
    "action",
    "resource",
    "reasonCodes",
    "issuedAt",
    "expiresAt",
    "bundleDigest",
    "summary",
    "limitations",
    "signature"
  ],
  "properties": {
    "schemaVersion": { "const": "fenrua.receipt.v1" },
    "receiptId": {
      "type": "string",
      "minLength": 20,
      "maxLength": 117,
      "pattern": "^urn:fenrua:receipt:[a-z0-9][a-z0-9-]{0,95}$"
    },
    "bundleId": {
      "type": "string",
      "minLength": 28,
      "maxLength": 125,
      "pattern": "^urn:fenrua:evidence-bundle:[a-z0-9][a-z0-9-]{0,95}$"
    },
    "decisionId": {
      "type": "string",
      "minLength": 21,
      "maxLength": 118,
      "pattern": "^urn:fenrua:decision:[a-z0-9][a-z0-9-]{0,95}$"
    },
    "decision": { "enum": ["ALLOW", "DENY"] },
    "subjectId": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/EntityId" },
    "actorId": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Identifier" },
    "action": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Action" },
    "resource": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Resource" },
    "reasonCodes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/ReasonCode" }
    },
    "issuedAt": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/UtcDateTimeMillis" },
    "expiresAt": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/UtcDateTimeMillis" },
    "bundleDigest": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Digest" },
    "summary": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/LongText" },
    "limitations": {
      "type": "array",
      "maxItems": 32,
      "items": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Limitation" }
    },
    "signature": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Signature" }
  }
}
