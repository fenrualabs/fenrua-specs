{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:fenrua:schema:verification-result-v1",
  "title": "Fenrua independent verification result v1",
  "description": "A verifier output. It is neither an evaluation request nor an authorisation decision.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "verificationId",
    "scope",
    "target",
    "verifier",
    "verificationState",
    "findings",
    "checkedAt",
    "expiresAt",
    "inputDigest",
    "evidenceDigest",
    "limitations",
    "signature"
  ],
  "properties": {
    "schemaVersion": { "const": "fenrua.verification-result.v1" },
    "verificationId": {
      "type": "string",
      "minLength": 25,
      "maxLength": 122,
      "pattern": "^urn:fenrua:verification:[a-z0-9][a-z0-9-]{0,95}$"
    },
    "scope": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Scope" },
    "target": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/EvidenceReference" },
    "verifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verifierId", "version", "profile"],
      "properties": {
        "verifierId": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Identifier" },
        "version": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Semver" },
        "profile": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/SignatureProfile" }
      }
    },
    "verificationState": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/VerificationState" },
    "findings": {
      "type": "array",
      "maxItems": 128,
      "items": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Finding" }
    },
    "checkedAt": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/UtcDateTimeMillis" },
    "expiresAt": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/UtcDateTimeMillis" },
    "inputDigest": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Digest" },
    "evidenceDigest": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Digest" },
    "limitations": {
      "type": "array",
      "maxItems": 32,
      "items": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Limitation" }
    },
    "signature": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Signature" }
  }
}
