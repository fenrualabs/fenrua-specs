{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:fenrua:schema:tool-call-request-v1",
  "title": "Fenrua tool call request v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestId",
    "scope",
    "subjectId",
    "actorId",
    "action",
    "resource",
    "context",
    "issuedAt",
    "expiresAt",
    "nonce",
    "replayRequired",
    "payloadDigest",
    "signature"
  ],
  "properties": {
    "schemaVersion": { "const": "fenrua.tool-call-request.v1" },
    "requestId": {
      "type": "string",
      "minLength": 25,
      "maxLength": 122,
      "pattern": "^urn:fenrua:tool-call-request:[a-z0-9][a-z0-9-]{0,95}$"
    },
    "scope": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Scope" },
    "subjectId": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/EntityId" },
    "actorId": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Identifier" },
    "action": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Action" },
    "resource": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Resource" },
    "context": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Context" },
    "issuedAt": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/UtcDateTimeMillis" },
    "expiresAt": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/UtcDateTimeMillis" },
    "nonce": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Base64Url" },
    "sequence": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Revision" },
    "challenge": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Base64Url" },
    "replayRequired": { "type": "boolean" },
    "payloadDigest": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Digest" },
    "artifact": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/ArtifactRef" },
    "policyRefs": {
      "type": "array",
      "maxItems": 16,
      "items": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/PolicyRef" }
    },
    "signature": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Signature" }
  }
}
