{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:fenrua:schema:decision-v1",
  "title": "Fenrua decision v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "decisionId",
    "scope",
    "profileId",
    "decision",
    "verificationState",
    "reasonCodes",
    "subjectId",
    "actorId",
    "action",
    "resource",
    "policyId",
    "policyRevision",
    "requestDigest",
    "evidenceBundleId",
    "issuedAt",
    "expiresAt",
    "limitations"
  ],
  "properties": {
    "schemaVersion": { "const": "fenrua.decision.v1" },
    "decisionId": {
      "type": "string",
      "minLength": 21,
      "maxLength": 118,
      "pattern": "^urn:fenrua:decision:[a-z0-9][a-z0-9-]{0,95}$"
    },
    "scope": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Scope" },
    "profileId": {
      "type": "string",
      "minLength": 35,
      "maxLength": 132,
      "pattern": "^urn:fenrua:compatibility-profile:[a-z0-9][a-z0-9-]{0,95}$"
    },
    "decision": { "enum": ["ALLOW", "DENY"] },
    "verificationState": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/VerificationState" },
    "reasonCodes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/ReasonCode" }
    },
    "subjectId": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/EntityId" },
    "actorId": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Identifier" },
    "action": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Action" },
    "resource": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Resource" },
    "policyId": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/PolicyId" },
    "policyRevision": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Revision" },
    "requestDigest": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Digest" },
    "evidenceBundleId": {
      "type": "string",
      "minLength": 28,
      "maxLength": 125,
      "pattern": "^urn:fenrua:evidence-bundle:[a-z0-9][a-z0-9-]{0,95}$"
    },
    "issuedAt": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/UtcDateTimeMillis" },
    "expiresAt": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/UtcDateTimeMillis" },
    "limitations": {
      "type": "array",
      "maxItems": 32,
      "items": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Limitation" }
    },
    "signature": { "$ref": "urn:fenrua:schema:shared-definitions-v1#/$defs/Signature" }
  }
}
