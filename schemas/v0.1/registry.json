      "role": "output"
    },
    {
      "schemaVersion": "fenrua.evidence-bundle.v1",
      "$id": "urn:fenrua:schema:evidence-bundle-v1",
      "path": "schemas/v0.1/evidence-bundle.schema.json",
      "role": "output"
    },
    {
      "schemaVersion": "fenrua.receipt.v1",
      "$id": "urn:fenrua:schema:receipt-v1",
