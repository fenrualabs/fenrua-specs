{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:fenrua:schema-registry:v0-1",
  "registryFormat": "fenrua.schema-registry.v1",
  "maturity": "R1-specification",
  "releaseState": "no-trust-gate-or-sdk-release",
  "schemaDialect": "https://json-schema.org/draft/2020-12/schema",
