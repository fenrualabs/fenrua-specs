      "path": "schemas/v0.1/authority-policy.schema.json",
      "role": "input"
    },
    {
      "schemaVersion": "fenrua.tool-call-request.v1",
      "$id": "urn:fenrua:schema:tool-call-request-v1",
      "path": "schemas/v0.1/tool-call-request.schema.json",
      "role": "input"
    },
    {
      "schemaVersion": "fenrua.approval.v1",
      "$id": "urn:fenrua:schema:approval-v1",
      "path": "schemas/v0.1/approval.schema.json",
      "role": "input"
    },
    {
      "schemaVersion": "fenrua.revocation-set.v1",
